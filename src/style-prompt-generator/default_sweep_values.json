{
    "method": "bayes",
    "metric": {
        "name": "cv/mean_val_loss",
        "goal": "minimize"
    },
    "parameters": {
        "learning_rate": {
            "distribution": "log_uniform_values",
            "min": 1e-5,
            "max": 1e-3
        },
        "weight_decay": {
            "distribution": "log_uniform_values",
            "min": 1e-4,
            "max": 1e-2
        },
        "dropout": {
            "values": [
                0.1,
                0.2,
                0.3
            ]
        },
        "num_unfrozen_embedder_layers": {
            "values": [
                0,
                1,
                2
            ]
        },
        "num_turns": {
            "values": [
                1,
                3,
                5
            ]
        }
    }
}